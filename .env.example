# Aquad'or Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# Supabase Configuration
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (KEEP SECRET - Server-side only)
# Required for:
# - Admin setup (src/app/api/admin/setup/route.ts)
# - Build-time AI catalogue generation (scripts/generate-ai-catalogue.ts)
# - Webhook order persistence (src/app/api/webhooks/stripe/route.ts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Stripe Payment Configuration
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret (for production webhooks)
# Get from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Application Configuration
# =============================================================================
# Base URL for redirects and webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# AI Assistant Configuration
# =============================================================================
# OpenRouter API Key (or OpenAI as fallback)
OPENROUTER_API_KEY=your-openrouter-api-key
# OPENAI_API_KEY=your-openai-key  # Alternative fallback

# Optional: Override AI endpoint and model
# AI_API_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
# AI_MODEL=google/gemini-2.0-flash-001

# =============================================================================
# Email Configuration (Resend)
# =============================================================================
RESEND_API_KEY=re_...
CONTACT_EMAIL_TO=info@aquadorcy.com

# =============================================================================
# Error Tracking (Sentry)
# =============================================================================
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# =============================================================================
# Rate Limiting (Upstash Redis) - Optional
# =============================================================================
# If not configured, rate limiting will be gracefully disabled
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token
